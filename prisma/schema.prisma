generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User role values: USER, ADMIN, DEMO
model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String?
  name                String
  image               String?
  role                String               @default("USER") // USER, ADMIN, DEMO
  isActive            Boolean              @default(true)
  isDemo              Boolean              @default(false)
  emailVerified       Boolean              @default(false)
  emailVerifyToken    String?              @unique
  emailVerifyExpires  DateTime?
  lastLoginAt         DateTime?
  clinicId            String?
  clinic              Clinic?              @relation(fields: [clinicId], references: [id])
  onboardingCompleted Boolean              @default(false)
  passwordResetTokens PasswordResetToken[]
  activityLogs        ActivityLog[]
  accounts            Account[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Plan values: BASIC, PRO, BUSINESS
// Sector values: SAGLIK, RESTORAN, OTEL, KUAFOR, GUZELLIK, DIGER
// MessagingPreference values: WHATSAPP, TELEGRAM, BOTH
model Clinic {
  id                    String                 @id @default(cuid())
  name                  String
  phone                 String?
  address               String?
  taxRate               Int                    @default(20)
  sector                String?
  plan                  String?                @default("PRO") // BASIC, PRO, BUSINESS
  selectedModules       String?                // JSON array string
  messagingPreference   String?                // WHATSAPP, TELEGRAM, BOTH
  workStartTime         String                 @default("09:00")
  workEndTime           String                 @default("17:30")
  users                 User[]
  patients              Patient[]
  treatments            Treatment[]
  expenses              Expense[]
  reminders             Reminder[]
  appointments          Appointment[]
  clinicSchedules       ClinicSchedule[]
  patientPreferences    PatientPreference[]
  patientVisitPatterns  PatientVisitPattern[]
  reminderLogs          ReminderLog[]
  employees             Employee[]
  products              Product[]
  stockMovements        StockMovement[]
  invoices              Invoice[]
  recurringTransactions RecurringTransaction[]
  subscriptions         Subscription[]
  telegramChatId        String?
  telegramLinks         TelegramLink[]
  whatsappPhone         String?
  whatsappConnected     Boolean                @default(false)
  clinicModules         ClinicModule[]
  onboardingChats       OnboardingChat[]
  uploadedInvoices      UploadedInvoice[]
  financialReports      FinancialReport[]
  metaAppId             String?
  metaAccessToken       String?                // AES-256 encrypted
  metaAdAccountId       String?
  metaConnected         Boolean                @default(false)
  metaTokenExpiresAt    DateTime?
  metaAdsConnection     MetaAdsConnection?
  adCampaigns           AdCampaign[]
  adCampaignMetrics     AdCampaignMetric[]
  socialMediaAssets     SocialMediaAsset[]
  scheduledPosts        ScheduledPost[]
  storageLimitMB        Int                    @default(1024)
  storageUsedMB         Int                    @default(0)
  storagePlan           String                 @default("free")
  tokenBalance          TokenBalance?
  tokenTransactions     TokenTransaction[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Patient {
  id           String               @id @default(cuid())
  name         String
  phone        String?
  email        String?
  notes        String?
  clinicId     String
  clinic       Clinic               @relation(fields: [clinicId], references: [id])
  treatments   Treatment[]
  appointments Appointment[]
  preferences  PatientPreference[]
  visitPattern PatientVisitPattern?
  reminderLogs ReminderLog[]
  invoices     Invoice[]
  photos       PatientPhoto[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

// TreatmentCategory values: BOTOX, DOLGU, DIS_TEDAVI, GENEL
// SQLite doesn't support enums, using String instead

model Treatment {
  id          String    @id @default(cuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id])
  clinicId    String
  clinic      Clinic    @relation(fields: [clinicId], references: [id])
  name        String
  description String?
  amount      Int // kuruş cinsinden
  date        DateTime  @default(now())
  category    String    @default("GENEL") // BOTOX, DOLGU, DIS_TEDAVI, GENEL
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Expense type values: EXPENSE, INCOME
model Expense {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  description String
  amount      Int // kuruş cinsinden
  category    String
  type        String   @default("EXPENSE") // EXPENSE, INCOME
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reminder {
  id                String   @id @default(cuid())
  treatmentCategory String // BOTOX, DOLGU, DIS_TEDAVI, GENEL
  intervalDays      Int      @default(180)
  messageTemplate   String
  isActive          Boolean  @default(true)
  clinicId          String
  clinic            Clinic   @relation(fields: [clinicId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Appointment status values: SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
model Appointment {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id])
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])
  date          DateTime // sadece tarih (gün)
  startTime     String // "09:00" formatında
  endTime       String // "09:30" formatında
  status        String    @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
  treatmentType String    @default("GENEL") // BOTOX, DOLGU, DIS_TEDAVI, GENEL
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ClinicSchedule {
  id           String  @id @default(cuid())
  clinicId     String
  clinic       Clinic  @relation(fields: [clinicId], references: [id])
  dayOfWeek    Int // 0=Pazar, 1=Pazartesi, ..., 6=Cumartesi
  startTime    String  @default("09:00")
  endTime      String  @default("18:00")
  slotDuration Int     @default(30) // dakika
  isActive     Boolean @default(true)
}

// PatientPreference type values: INDIRIM_SEVER, HEDIYE_SEVER, ARKADASIYLA_GELIR, SADIK_MUSTERI, FIYAT_HASSAS
model PatientPreference {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  type      String // INDIRIM_SEVER, HEDIYE_SEVER, ARKADASIYLA_GELIR, SADIK_MUSTERI, FIYAT_HASSAS
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// PatientVisitPattern lastCategory values: BOTOX, DOLGU, DIS_TEDAVI, GENEL
model PatientVisitPattern {
  id               String    @id @default(cuid())
  patientId        String    @unique
  patient          Patient   @relation(fields: [patientId], references: [id])
  clinicId         String
  clinic           Clinic    @relation(fields: [clinicId], references: [id])
  averageVisitDays Int? // Average days between visits
  lastVisitDate    DateTime?
  totalVisits      Int       @default(0)
  lastCategory     String? // Last treatment category
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ReminderLog channel values: WHATSAPP, TELEGRAM, SMS
// ReminderLog status values: PENDING, SENT, FAILED
model ReminderLog {
  id             String    @id @default(cuid())
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id])
  clinicId       String
  clinic         Clinic    @relation(fields: [clinicId], references: [id])
  messageContent String
  channel        String    @default("WHATSAPP") // WHATSAPP, TELEGRAM, SMS
  status         String    @default("PENDING") // PENDING, SENT, FAILED
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
}

// Employee role values: DOKTOR, ASISTAN, SEKRETER, TEKNISYEN, DIGER
model Employee {
  id             String        @id @default(cuid())
  name           String
  role           String        @default("ASISTAN") // DOKTOR, ASISTAN, SEKRETER, TEKNISYEN, DIGER
  phone          String?
  email          String?
  userId         String?
  color          String        @default("#3b82f6")
  commissionRate Int           @default(0) // yüzde cinsinden (ör: 10 = %10)
  permissions    Json?
  isActive       Boolean       @default(true)
  clinicId       String
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  treatments     Treatment[]
  appointments   Appointment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ProductCategory values: KOZMETIK, MEDIKAL, SARF_MALZEME, DIGER
// ProductUnit values: ADET, KUTU, ML, GR
model Product {
  id               String          @id @default(cuid())
  name             String
  sku              String          @unique
  brand            String?
  category         String          @default("DIGER") // KOZMETIK, MEDIKAL, SARF_MALZEME, DIGER
  unit             String          @default("ADET") // ADET, KUTU, ML, GR
  currentStock     Int             @default(0)
  minStock         Int             @default(0)
  orderAlert       Boolean         @default(false)
  purchasePrice    Int             @default(0) // kuruş (TL)
  purchasePriceUSD Float?          // Alış fiyatı USD
  currency         String          @default("TRY") // TRY, USD, EUR
  minProfitMargin  Int             @default(20) // minimum kar oranı %
  salePrice        Int             @default(0) // kuruş
  clinicId         String
  clinic           Clinic          @relation(fields: [clinicId], references: [id])
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  movements        StockMovement[]
}

// StockMovementType values: IN, OUT, ADJUSTMENT
model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  type        String // IN, OUT, ADJUSTMENT
  quantity    Int
  unitPrice   Int      @default(0) // kuruş
  totalPrice  Int      @default(0) // kuruş
  description String?
  reference   String? // fatura no vb.
  date        DateTime @default(now())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())
}

// Invoice type values: EFATURA, EARSIV
// Invoice status values: DRAFT, SENT, APPROVED, CANCELLED
model Invoice {
  id                String     @id @default(cuid())
  invoiceNumber     String     @unique
  type              String // EFATURA, EARSIV
  status            String     @default("DRAFT") // DRAFT, SENT, APPROVED, CANCELLED
  customerName      String
  customerTaxNumber String?
  customerTaxOffice String?
  customerAddress   String?
  customerEmail     String?
  items             Json // [{description, quantity, unitPrice, taxRate, total}]
  subtotal          Int // kuruş
  taxRate           Int        @default(20)
  taxAmount         Int // kuruş
  total             Int // kuruş
  notes             String?
  issueDate         DateTime
  dueDate           DateTime?
  clinicId          String
  clinic            Clinic     @relation(fields: [clinicId], references: [id])
  patientId         String?
  patient           Patient?   @relation(fields: [patientId], references: [id])
  treatmentId       String?
  treatment         Treatment? @relation(fields: [treatmentId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model RecurringTransaction {
  id           String             @id @default(cuid())
  clinicId     String
  clinic       Clinic             @relation(fields: [clinicId], references: [id])
  type         String // "INCOME" or "EXPENSE"
  category     String // "FIXED" or "VARIABLE"
  name         String
  amount       Float?
  currency     String             @default("TRY")
  dayOfMonth   Int
  isActive     Boolean            @default(true)
  remindBefore Int                @default(3)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  payments     RecurringPayment[]
}

model RecurringPayment {
  id                     String               @id @default(cuid())
  recurringTransactionId String
  recurringTransaction   RecurringTransaction @relation(fields: [recurringTransactionId], references: [id])
  clinicId               String
  amount                 Float
  paidAt                 DateTime?
  dueDate                DateTime
  status                 String               @default("PENDING") // PENDING, PAID, OVERDUE, SKIPPED
  notes                  String?
  createdAt              DateTime             @default(now())
}

model Subscription {
  id                    String                @id @default(cuid())
  clinicId              String
  clinic                Clinic                @relation(fields: [clinicId], references: [id])
  plan                  String // "STARTER", "PROFESSIONAL", "BUSINESS"
  price                 Float
  currency              String                @default("TRY")
  status                String                @default("ACTIVE") // ACTIVE, CANCELLED, PAST_DUE, TRIAL
  trialEndsAt           DateTime?
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  iyzicoSubscriptionRef String?
  cardToken             String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  payments              SubscriptionPayment[]
}

model SubscriptionPayment {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  amount          Float
  status          String // SUCCESS, FAILED, PENDING
  iyzicoPaymentId String?
  paidAt          DateTime?
  createdAt       DateTime     @default(now())
}

// ═══════════════════════════════════════════════════════════
// Modüler Fiyatlandırma
// ═══════════════════════════════════════════════════════════

model Module {
  id            String         @id @default(cuid())
  name          String         @unique
  displayName   String
  description   String
  price         Float
  icon          String?
  isCore        Boolean        @default(false)
  createdAt     DateTime       @default(now())
  clinicModules ClinicModule[]
}

model ClinicModule {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id])
  isActive    Boolean  @default(true)
  activatedAt DateTime @default(now())

  @@unique([clinicId, moduleId])
}

// ═══════════════════════════════════════════════════════════
// AI Onboarding Chat
// ═══════════════════════════════════════════════════════════

model OnboardingChat {
  id               String   @id @default(cuid())
  sessionId        String   @unique @default(cuid())
  clinicId         String?
  clinic           Clinic?  @relation(fields: [clinicId], references: [id])
  messages         Json
  suggestedModules Json?
  selectedModules  Json?
  totalPrice       Float?
  completed        Boolean  @default(false)
  createdAt        DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════
// Fatura OCR & Mali Tablo
// ═══════════════════════════════════════════════════════════

// UploadedInvoice status values: PENDING, PROCESSING, COMPLETED, FAILED
model UploadedInvoice {
  id              String    @id @default(cuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  fileName        String
  fileUrl         String
  fileType        String
  ocrData         Json?
  status          String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  invoiceType     String    @default("EXPENSE") // EXPENSE, INCOME
  category        String?
  amount          Float?
  invoiceDate     DateTime?
  vendor          String?
  linkedExpenseId String?
  approved        Boolean   @default(false)
  createdAt       DateTime  @default(now())
}

model FinancialReport {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  month     Int
  year      Int
  data      Json
  createdAt DateTime @default(now())

  @@unique([clinicId, month, year])
}

// ═══════════════════════════════════════════════════════════
// Telegram QR Bağlantı
// ═══════════════════════════════════════════════════════════

model TelegramLink {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  code      String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════
// Hasta Fotoğraf Yönetimi
// ═══════════════════════════════════════════════════════════

// PatientPhoto category values: GENERAL, BEFORE, AFTER, XRAY, OTHER
model PatientPhoto {
  id         String    @id @default(cuid())
  patientId  String
  patient    Patient   @relation(fields: [patientId], references: [id])
  fileName   String
  fileUrl    String
  category   String    @default("GENERAL") // GENERAL, BEFORE, AFTER, XRAY, OTHER
  notes      String?
  takenAt    DateTime?
  uploadedAt DateTime  @default(now())
}

// ═══════════════════════════════════════════════════════════
// Instagram / Meta Ads
// ═══════════════════════════════════════════════════════════

model MetaAdsConnection {
  id          String   @id @default(cuid())
  clinicId    String   @unique
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  appId       String?
  accessToken String
  adAccountId String
  pageId      String?
  connectedAt DateTime @default(now())
}

model AdCampaign {
  id              String    @id @default(cuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  metaCampaignId  String?
  metaAdSetId     String?
  metaAdId        String?
  name            String
  objective       String
  status          String    @default("PAUSED")
  dailyBudget     Float
  startDate       DateTime
  endDate         DateTime?
  targetCity      String?
  targetAgeMin    Int       @default(18)
  targetAgeMax    Int       @default(65)
  targetGender    String    @default("ALL")
  interests       String?
  platforms       String    @default("BOTH")
  imageUrl        String?
  headline        String?
  description     String?
  ctaType         String?
  websiteUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AdCampaignMetric {
  id           String   @id @default(cuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  campaignId   String
  campaignName String
  date         DateTime
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  spend        Float    @default(0)
  conversions  Int      @default(0)
  cpc          Float?
  cpm          Float?
  ctr          Float?
  fetchedAt    DateTime @default(now())

  @@unique([clinicId, campaignId, date])
}

// ═══════════════════════════════════════════════════════════
// Sosyal Medya İçerik
// ═══════════════════════════════════════════════════════════

model SocialMediaAsset {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  fileName  String
  fileUrl   String
  type      String
  createdAt DateTime @default(now())
}

// ScheduledPost status values: SCHEDULED, POSTED, FAILED, CANCELLED
model ScheduledPost {
  id              String    @id @default(cuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  type            String
  platform        String
  content         String?
  imageUrl        String?
  scheduledAt     DateTime
  postedAt        DateTime?
  status          String    @default("SCHEDULED") // SCHEDULED, POSTED, FAILED, CANCELLED
  isAutoGenerated Boolean   @default(false)
  occasion        String?
  createdAt       DateTime  @default(now())
}

// ═══════════════════════════════════════════════════════════
// Token Bazlı Fiyatlandırma
// ═══════════════════════════════════════════════════════════

model TokenBalance {
  id          String   @id @default(cuid())
  clinicId    String   @unique
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  balance     Int      @default(50000)
  totalUsed   Int      @default(0)
  totalBought Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model TokenTransaction {
  id           String   @id @default(cuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  type         String   // "USE" or "ADD"
  amount       Int
  action       String?
  description  String?
  balanceAfter Int
  createdAt    DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════
// Activity Log
// ═══════════════════════════════════════════════════════════

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clinicId  String?
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}
