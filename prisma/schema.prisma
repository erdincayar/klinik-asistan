// ═══════════════════════════════════════════════════════════
// Poby Asistan
// ═══════════════════════════════════════════════════════════

// ClinicKnowledgeBase source_type values: manual, document, whatsapp_export, whatsapp_learned
model ClinicKnowledgeBase {
  id             String                      @id @default(cuid())
  clinicId       String
  clinic         Clinic                      @relation(fields: [clinicId], references: [id])
  sourceType     String                      // manual, document, whatsapp_export, whatsapp_learned
  sourceFilename String?
  content        String                      @db.Text
  embedding      Unsupported("vector(1536)")?
  metadata       Json?
  createdAt      DateTime                    @default(now())
}

// ClinicAssistantConfig tone values: warm, formal, informative
// response_length values: short, medium, detailed
// emoji_usage values: none, minimal, normal
// language values: tr, en, both
model ClinicAssistantConfig {
  id                        String    @id @default(cuid())
  clinicId                  String    @unique
  clinic                    Clinic    @relation(fields: [clinicId], references: [id])
  isActive                  Boolean   @default(false)
  assistantName             String    @default("Asistan") @db.VarChar(100)
  tone                      String    @default("warm")
  responseLength            String    @default("medium")
  emojiUsage                String    @default("minimal")
  language                  String    @default("tr")
  capabilities              Json      @default("{\"answer_services\":true,\"answer_hours\":true,\"answer_location\":true,\"send_location\":false,\"book_appointment\":false,\"modify_appointment\":false,\"cancel_appointment\":false,\"query_appointment\":false,\"suggest_products\":false,\"share_campaigns\":false}")
  learnedStylePrompt        String?   @db.Text
  whatsappExportProcessed   Boolean   @default(false)
  whatsappConversationCount Int       @default(0)
  lastLearnedAt             DateTime?
  systemPromptOverride      String?   @db.Text
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

// ClinicConversation channel values: whatsapp, telegram, instagram
model ClinicConversation {
  id                    String                 @id @default(cuid())
  clinicId              String
  clinic                Clinic                 @relation(fields: [clinicId], references: [id])
  channel               String                 // whatsapp, telegram, instagram
  customerPhone         String?
  customerChatId        String?
  customerName          String?
  messages              Json                   // [{role, content, timestamp}]
  lastMessageAt         DateTime
  assistantAppointments AssistantAppointment[]
  createdAt             DateTime               @default(now())
}

// AssistantAppointment status values: pending, confirmed, cancelled
model AssistantAppointment {
  id              String              @id @default(cuid())
  clinicId        String
  clinic          Clinic              @relation(fields: [clinicId], references: [id])
  conversationId  String?
  conversation    ClinicConversation? @relation(fields: [conversationId], references: [id])
  customerName    String
  customerPhone   String
  serviceName     String
  appointmentDate DateTime
  notes           String?             @db.Text
  status          String              @default("pending") // pending, confirmed, cancelled
  sourceChannel   String
  createdAt       DateTime            @default(now())
}

