generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User role values: USER, ADMIN, DEMO
model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String?
  name                String
  image               String?
  role                String               @default("USER") // USER, ADMIN, DEMO
  isActive            Boolean              @default(true)
  isDemo              Boolean              @default(false)
  emailVerified       Boolean              @default(false)
  emailVerifyToken    String?              @unique
  emailVerifyExpires  DateTime?
  lastLoginAt         DateTime?
  telegramChatId      String?              // Kullanıcının kendi Telegram chat ID'si
  clinicId            String?
  clinic              Clinic?              @relation(fields: [clinicId], references: [id])
  onboardingCompleted Boolean              @default(false)
  passwordResetTokens PasswordResetToken[]
  activityLogs        ActivityLog[]
  accounts            Account[]
  telegramLinks       TelegramLink[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Plan values: BASIC, PRO, BUSINESS
// Sector values: SAGLIK, RESTORAN, OTEL, KUAFOR, GUZELLIK, DIGER
// MessagingPreference values: WHATSAPP, TELEGRAM, BOTH
model Clinic {
  id                    String                 @id @default(cuid())
  name                  String
  phone                 String?
  address               String?
  taxRate               Int                    @default(20)
  sector                String?
  plan                  String?                @default("PRO") // BASIC, PRO, BUSINESS
  selectedModules       String?                // JSON array string
  messagingPreference   String?                // WHATSAPP, TELEGRAM, BOTH
  workStartTime         String                 @default("09:00")
  workEndTime           String                 @default("17:30")
  users                 User[]
  patients              Patient[]
  treatments            Treatment[]
  expenses              Expense[]
  reminders             Reminder[]
  appointments          Appointment[]
  clinicSchedules       ClinicSchedule[]
  patientPreferences    PatientPreference[]
  patientVisitPatterns  PatientVisitPattern[]
  reminderLogs          ReminderLog[]
  employees             Employee[]
  products              Product[]
  stockMovements        StockMovement[]
  invoices              Invoice[]
  recurringTransactions RecurringTransaction[]
  subscriptions         Subscription[]
  telegramChatId        String?
  telegramLinks         TelegramLink[]
  whatsappPhone         String?
  whatsappConnected     Boolean                @default(false)
  clinicModules         ClinicModule[]
  consentForms          ConsentForm[]
  onboardingChats       OnboardingChat[]
  onboardingProfiles    OnboardingProfile[]
  uploadedInvoices      UploadedInvoice[]
  financialReports      FinancialReport[]
  metaAppId             String?
  metaAccessToken       String?                // AES-256 encrypted
  metaAdAccountId       String?
  metaConnected         Boolean                @default(false)
  metaTokenExpiresAt    DateTime?
  metaAdsConnection     MetaAdsConnection?
  adCampaigns           AdCampaign[]
  adCampaignMetrics     AdCampaignMetric[]
  socialMediaAssets     SocialMediaAsset[]
  scheduledPosts        ScheduledPost[]
  storageLimitMB        Int                    @default(100)
  storageUsedMB         Int                    @default(0)
  storagePlan           String                 @default("free")
  photoCategories       String[]               @default(["Genel"])
  tokenBalance          TokenBalance?
  tokenTransactions     TokenTransaction[]
  stockAlarms           StockAlarm[]
  alarms                Alarm[]
  alarmLogs             AlarmLog[]
  fixedAssets           FixedAsset[]
  inventoryColumnConfig InventoryColumnConfig?
  employeeRoles         EmployeeRole[]
  employeeCustomFields  EmployeeCustomField[]
  hrDocuments           HrDocument[]
  styleProfile          ClinicStyleProfile?
  aiGeneratedContents   AiGeneratedContent[]
  assistantConfig       ClinicAssistantConfig?
  knowledgeBase         ClinicKnowledgeBase[]
  clinicConversations   ClinicConversation[]
  assistantAppointments AssistantAppointment[]
  clinicServiceNames    ClinicServiceName[]
  clinicCategories      ClinicCategory[]
  customerCustomColumns CustomerCustomColumn[]
  transactionCustomFields TransactionCustomField[]
  alertRules            CustomerAlertRule[]
  subscriptionPlan      SubscriptionPlan?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Patient {
  id           String               @id @default(cuid())
  name         String
  phone        String?
  email        String?
  notes        String?
  dateOfBirth  DateTime?
  clinicId     String
  clinic       Clinic               @relation(fields: [clinicId], references: [id])
  treatments   Treatment[]
  appointments Appointment[]
  preferences  PatientPreference[]
  visitPattern PatientVisitPattern?
  reminderLogs ReminderLog[]
  invoices     Invoice[]
  photos       PatientPhoto[]
  customValues CustomerCustomValue[]
  alarms                Alarm[]
  consentFormResponses  ConsentFormResponse[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

// TreatmentCategory values: BOTOX, DOLGU, DIS_TEDAVI, GENEL
// SQLite doesn't support enums, using String instead

model Treatment {
  id          String    @id @default(cuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id])
  clinicId    String
  clinic      Clinic    @relation(fields: [clinicId], references: [id])
  name        String
  description String?
  amount      Int // kuruş cinsinden
  date        DateTime  @default(now())
  category    String    @default("GENEL") // BOTOX, DOLGU, DIS_TEDAVI, GENEL
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  paymentMethod String?      // Nakit, Kart, Havale, Sigorta, Diger
  invoices      Invoice[]
  customValues  TransactionCustomValue[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Expense type values: EXPENSE, INCOME
model Expense {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  description String
  amount      Int // kuruş cinsinden
  category    String
  type        String   @default("EXPENSE") // EXPENSE, INCOME
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reminder {
  id                String   @id @default(cuid())
  treatmentCategory String // BOTOX, DOLGU, DIS_TEDAVI, GENEL
  intervalDays      Int      @default(180)
  messageTemplate   String
  isActive          Boolean  @default(true)
  clinicId          String
  clinic            Clinic   @relation(fields: [clinicId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Appointment status values: SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
model Appointment {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id])
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])
  date          DateTime // sadece tarih (gün)
  startTime     String // "09:00" formatında
  endTime       String // "09:30" formatında
  status        String    @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
  treatmentType String    @default("GENEL") // BOTOX, DOLGU, DIS_TEDAVI, GENEL
  notes         String?
  treatments    Treatment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ClinicSchedule {
  id           String  @id @default(cuid())
  clinicId     String
  clinic       Clinic  @relation(fields: [clinicId], references: [id])
  dayOfWeek    Int // 0=Pazar, 1=Pazartesi, ..., 6=Cumartesi
  startTime    String  @default("09:00")
  endTime      String  @default("18:00")
  slotDuration Int     @default(30) // dakika
  isActive     Boolean @default(true)
}

// PatientPreference type values: INDIRIM_SEVER, HEDIYE_SEVER, ARKADASIYLA_GELIR, SADIK_MUSTERI, FIYAT_HASSAS
model PatientPreference {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  type      String // INDIRIM_SEVER, HEDIYE_SEVER, ARKADASIYLA_GELIR, SADIK_MUSTERI, FIYAT_HASSAS
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// PatientVisitPattern lastCategory values: BOTOX, DOLGU, DIS_TEDAVI, GENEL
model PatientVisitPattern {
  id               String    @id @default(cuid())
  patientId        String    @unique
  patient          Patient   @relation(fields: [patientId], references: [id])
  clinicId         String
  clinic           Clinic    @relation(fields: [clinicId], references: [id])
  averageVisitDays Int? // Average days between visits
  lastVisitDate    DateTime?
  totalVisits      Int       @default(0)
  lastCategory     String? // Last treatment category
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ReminderLog channel values: WHATSAPP, TELEGRAM, SMS
// ReminderLog status values: PENDING, SENT, FAILED
model ReminderLog {
  id             String    @id @default(cuid())
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id])
  clinicId       String
  clinic         Clinic    @relation(fields: [clinicId], references: [id])
  messageContent String
  channel        String    @default("WHATSAPP") // WHATSAPP, TELEGRAM, SMS
  status         String    @default("PENDING") // PENDING, SENT, FAILED
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
}

model Employee {
  id                    String                 @id @default(cuid())
  name                  String
  role                  String                 @default("ASISTAN")
  phone                 String?
  email                 String?
  userId                String?
  color                 String                 @default("#3b82f6")
  commissionRate        Int                    @default(0) // yüzde cinsinden (ör: 10 = %10)
  tieredCommission      Boolean                @default(false) // kademeli komisyon aktif mi
  permissions           Json?
  isActive              Boolean                @default(true)
  salaryGross           Int?                   // Brüt maaş (kuruş)
  salaryNet             Int?                   // Net maaş (kuruş)
  salarySSI             Int?                   // SGK işveren payı (kuruş)
  salaryPayDay          Int?                   // Maaş ödeme günü (1-28)
  manualSalaryEntry     Boolean                @default(false)
  roleTemplate          String?                // full, view_only, custom
  hasSystemAccess       Boolean                @default(false)
  systemEmail           String?
  inviteStatus          String?                // not_invited, invited, active
  inviteToken           String?
  invitedAt             DateTime?
  clinicId              String
  clinic                Clinic                 @relation(fields: [clinicId], references: [id])
  treatments            Treatment[]
  appointments          Appointment[]
  recurringTransactions RecurringTransaction[]
  customValues          EmployeeCustomValue[]
  commissionTiers       CommissionTier[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model CommissionTier {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  minRevenue    Int      // Minimum ciro eşiği (kuruş) — bu cirodan itibaren geçerli
  commissionPct Float    // Komisyon yüzdesi (ör: 5.0 = %5)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([employeeId])
}

model EmployeeRole {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  name      String
  createdAt DateTime @default(now())

  @@unique([clinicId, name])
}

// Onam Formu şablonu — merkez tarafından oluşturulur
model ConsentForm {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  title       String   // Form başlığı (ör: "Botox Onam Formu")
  description String?  // Açıklama
  content     String   @db.Text // Form HTML/markdown içeriği
  fields      Json?    // Ek alanlar [{label, type, required}]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  responses   ConsentFormResponse[]

  @@index([clinicId])
}

// Müşteri tarafından doldurulan onam formu yanıtı
model ConsentFormResponse {
  id            String      @id @default(cuid())
  consentFormId String
  consentForm   ConsentForm @relation(fields: [consentFormId], references: [id], onDelete: Cascade)
  patientId     String?
  patient       Patient?    @relation(fields: [patientId], references: [id])
  patientName   String      // İsim (giriş yapmamış müşteri için)
  patientTc     String?     // TC Kimlik No
  signature     String?     @db.Text // Base64 imza verisi
  fieldValues   Json?       // Ek alan yanıtları
  signedAt      DateTime    @default(now())
  ipAddress     String?
  clinicId      String

  @@index([consentFormId])
  @@index([patientId])
}

model EmployeeCustomField {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  fieldName String
  fieldKey  String
  fieldType String   @default("text") // text, number, date
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([clinicId, fieldKey])
}

model EmployeeCustomValue {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fieldKey   String
  value      String?
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, fieldKey])
}

// ProductCategory values: KOZMETIK, MEDIKAL, SARF_MALZEME, DIGER
// ProductUnit values: ADET, KUTU, ML, GR
model Product {
  id               String          @id @default(cuid())
  name             String
  sku              String          @unique
  brand            String?
  category         String          @default("DIGER") // KOZMETIK, MEDIKAL, SARF_MALZEME, DIGER
  unit             String          @default("ADET") // ADET, KUTU, ML, GR
  currentStock     Int?
  minStock         Int             @default(0)
  orderAlert       Boolean         @default(false)
  purchasePrice    Int             @default(0) // kuruş (TL)
  purchasePriceUSD Float?          // Alış fiyatı USD
  currency         String          @default("TRY") // TRY, USD, EUR
  minProfitMargin  Int             @default(20) // minimum kar oranı %
  salePrice        Int             @default(0) // kuruş
  salePriceUSD     Float?          // Satış fiyatı döviz karşılığı
  saleCurrency     String          @default("TRY") // Satış para birimi
  customFields     Json?
  clinicId         String
  clinic           Clinic          @relation(fields: [clinicId], references: [id])
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  movements        StockMovement[]
  stockAlarms      StockAlarm[]

  @@unique([clinicId, name, unit])
}

// StockMovementType values: IN, OUT, ADJUSTMENT
model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  type        String // IN, OUT, ADJUSTMENT
  quantity    Int
  unitPrice   Int      @default(0) // kuruş
  totalPrice  Int      @default(0) // kuruş
  description String?
  reference   String? // fatura no vb.
  date        DateTime @default(now())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())
}

// Invoice type values: EFATURA, EARSIV
// Invoice status values: DRAFT, SENT, APPROVED, CANCELLED
model Invoice {
  id                String     @id @default(cuid())
  invoiceNumber     String     @unique
  type              String // EFATURA, EARSIV
  status            String     @default("DRAFT") // DRAFT, SENT, APPROVED, CANCELLED
  customerName      String
  customerTaxNumber String?
  customerTaxOffice String?
  customerAddress   String?
  customerEmail     String?
  items             Json // [{description, quantity, unitPrice, taxRate, total}]
  subtotal          Int // kuruş
  taxRate           Int        @default(20)
  taxAmount         Int // kuruş
  total             Int // kuruş
  notes             String?
  issueDate         DateTime
  dueDate           DateTime?
  clinicId          String
  clinic            Clinic     @relation(fields: [clinicId], references: [id])
  patientId         String?
  patient           Patient?   @relation(fields: [patientId], references: [id])
  treatmentId       String?
  treatment         Treatment? @relation(fields: [treatmentId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model RecurringTransaction {
  id           String             @id @default(cuid())
  clinicId     String
  clinic       Clinic             @relation(fields: [clinicId], references: [id])
  type         String // "INCOME" or "EXPENSE"
  category     String // "FIXED" or "VARIABLE"
  name         String
  amount       Float?
  currency     String             @default("TRY")
  dayOfMonth   Int
  isActive     Boolean            @default(true)
  remindBefore Int                @default(3)
  notes        String?
  employeeId   String?
  employee     Employee?          @relation(fields: [employeeId], references: [id])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  payments     RecurringPayment[]
}

model RecurringPayment {
  id                     String               @id @default(cuid())
  recurringTransactionId String
  recurringTransaction   RecurringTransaction @relation(fields: [recurringTransactionId], references: [id])
  clinicId               String
  amount                 Float
  paidAt                 DateTime?
  dueDate                DateTime
  status                 String               @default("PENDING") // PENDING, PAID, OVERDUE, SKIPPED
  notes                  String?
  createdAt              DateTime             @default(now())
}

model Subscription {
  id                    String                @id @default(cuid())
  clinicId              String
  clinic                Clinic                @relation(fields: [clinicId], references: [id])
  plan                  String // "STARTER", "PROFESSIONAL", "BUSINESS"
  price                 Float
  currency              String                @default("TRY")
  status                String                @default("ACTIVE") // ACTIVE, CANCELLED, PAST_DUE, TRIAL
  trialEndsAt           DateTime?
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  iyzicoSubscriptionRef String?
  cardToken             String?
  expiresAt             DateTime?
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  payments              SubscriptionPayment[]
}

model SubscriptionPayment {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  amount          Float
  status          String // SUCCESS, FAILED, PENDING
  iyzicoPaymentId String?
  paytrOrderId    String?
  paytrToken      String?
  paymentType     String       @default("SUBSCRIPTION") // SUBSCRIPTION, TOKEN_PACKAGE, STORAGE_PACKAGE
  packageId       String?
  paidAt          DateTime?
  createdAt       DateTime     @default(now())
}

// ═══════════════════════════════════════════════════════════
// Modüler Fiyatlandırma
// ═══════════════════════════════════════════════════════════

model Module {
  id            String         @id @default(cuid())
  name          String         @unique
  displayName   String
  description   String
  price         Float
  icon          String?
  isCore        Boolean        @default(false)
  createdAt     DateTime       @default(now())
  clinicModules ClinicModule[]
}

model ClinicModule {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id])
  isActive    Boolean  @default(true)
  activatedAt DateTime @default(now())

  @@unique([clinicId, moduleId])
}

// ═══════════════════════════════════════════════════════════
// AI Onboarding Chat
// ═══════════════════════════════════════════════════════════

model OnboardingChat {
  id               String   @id @default(cuid())
  sessionId        String   @unique @default(cuid())
  clinicId         String?
  clinic           Clinic?  @relation(fields: [clinicId], references: [id])
  messages         Json
  suggestedModules Json?
  selectedModules  Json?
  totalPrice       Float?
  completed        Boolean  @default(false)
  createdAt        DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════
// Fatura OCR & Mali Tablo
// ═══════════════════════════════════════════════════════════

// UploadedInvoice status values: PENDING, PROCESSING, COMPLETED, FAILED
model UploadedInvoice {
  id              String    @id @default(cuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  fileName        String
  fileUrl         String
  fileType        String
  ocrData         Json?
  status          String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  invoiceType     String    @default("EXPENSE") // EXPENSE, INCOME
  category        String?
  amount          Float?
  invoiceDate     DateTime?
  vendor          String?
  linkedExpenseId String?
  approved        Boolean   @default(false)
  profitData      Json?
  createdAt       DateTime  @default(now())
}

model FinancialReport {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  month     Int
  year      Int
  data      Json
  createdAt DateTime @default(now())

  @@unique([clinicId, month, year])
}

// ═══════════════════════════════════════════════════════════
// Telegram QR Bağlantı
// ═══════════════════════════════════════════════════════════

model TelegramLink {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  code      String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════
// Hasta Fotoğraf Yönetimi
// ═══════════════════════════════════════════════════════════

// PatientPhoto category values: GENERAL, BEFORE, AFTER, XRAY, OTHER
model PatientPhoto {
  id         String    @id @default(cuid())
  patientId  String
  patient    Patient   @relation(fields: [patientId], references: [id])
  fileName   String
  fileUrl    String
  category   String    @default("GENERAL") // GENERAL, BEFORE, AFTER, XRAY, OTHER
  notes      String?
  takenAt    DateTime?
  uploadedAt DateTime  @default(now())
}

// ═══════════════════════════════════════════════════════════
// Instagram / Meta Ads
// ═══════════════════════════════════════════════════════════

model MetaAdsConnection {
  id          String   @id @default(cuid())
  clinicId    String   @unique
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  appId       String?
  accessToken String
  adAccountId String
  pageId      String?
  connectedAt DateTime @default(now())
}

model AdCampaign {
  id              String    @id @default(cuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  metaCampaignId  String?
  metaAdSetId     String?
  metaAdId        String?
  name            String
  objective       String
  status          String    @default("PAUSED")
  dailyBudget     Float
  startDate       DateTime
  endDate         DateTime?
  targetCity      String?
  targetAgeMin    Int       @default(18)
  targetAgeMax    Int       @default(65)
  targetGender    String    @default("ALL")
  interests       String?
  platforms       String    @default("BOTH")
  imageUrl        String?
  headline        String?
  description     String?
  ctaType         String?
  websiteUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AdCampaignMetric {
  id           String   @id @default(cuid())
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  campaignId   String
  campaignName String
  date         DateTime
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  spend        Float    @default(0)
  conversions  Int      @default(0)
  cpc          Float?
  cpm          Float?
  ctr          Float?
  fetchedAt    DateTime @default(now())

  @@unique([clinicId, campaignId, date])
}

