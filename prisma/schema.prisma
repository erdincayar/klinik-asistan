// ═══════════════════════════════════════════════════════════
// Stok Alarm & Demirbaş
// ═══════════════════════════════════════════════════════════

// StockAlarm type values: STOCK, PROFIT_MARGIN, CURRENCY
model StockAlarm {
  id            String    @id @default(cuid())
  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id])
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id])
  name          String
  type          String    // STOCK, PROFIT_MARGIN, CURRENCY
  threshold     Float
  currency      String?
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  createdAt     DateTime  @default(now())
}

model Alarm {
  id              String    @id @default(cuid())
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name            String
  type            String    // STOCK, CUSTOMER_VISIT, CUSTOMER_BIRTHDAY, FINANCE
  conditions      Json
  isActive        Boolean   @default(true)
  isGroup         Boolean   @default(false)
  groupName       String?
  customerId      String?
  customer        Patient?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  logs            AlarmLog[]

  @@index([clinicId, groupName])
  @@index([clinicId, customerId])
}

model AlarmLog {
  id         String   @id @default(cuid())
  alarmId    String
  alarm      Alarm    @relation(fields: [alarmId], references: [id], onDelete: Cascade)
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  message    String
  entityId   String?
  entityName String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([clinicId, isRead])
  @@index([alarmId])
}

model InventoryColumnConfig {
  id        String   @id @default(cuid())
  clinicId  String   @unique
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  columns   Json     // { order: string[], hidden: string[], customColumns: CustomColumn[] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

