# Anthropic API key (product extraction + translation)
ANTHROPIC_API_KEY=

# Claude model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override default port (8001)
CATALOG_SERVICE_PORT=8001

# Optional: extra comma-separated CORS origins
# CATALOG_EXTRA_ORIGINS=https://staging.poby.ai

# Shared storage root with Next.js side. Default: /var/www/klinik-asistan/storage
# Relative paths coming from Next.js are resolved against this root.
CATALOG_STORAGE_ROOT=/var/www/klinik-asistan/storage

# Max pages per extract-products Claude batch (default 5)
# CATALOG_EXTRACT_BATCH=5

# Max products per translate Claude batch (default 10)
# CATALOG_TRANSLATE_BATCH=10

# Set to any truthy value to enable uvicorn --reload
# CATALOG_DEV_MODE=1
